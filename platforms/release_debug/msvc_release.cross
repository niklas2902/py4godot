[built-in options]
cpp_args = [
    '/O1', '/Oi', '/Oy',
    '/Gy', '/Gw',
    '/Zc:inline',
    '/Zc:threadSafeInit-',
    '/GS-',
    '/fp:fast',
    '/bigobj',
    '/DNDEBUG']

cpp_link_args = [
    '/OPT:REF',
    '/OPT:ICF=3',
    '/INCREMENTAL:NO',
    '/VERBOSE']
[properties]
buildtype = 'release'
